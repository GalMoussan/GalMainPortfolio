# AI Integration Landing Page Environment Variables

# Resend API Key for email capture form
# Get your key at https://resend.com/api-keys after creating an account and verifying your domain
RESEND_API_KEY=

# WhatsApp number for primary CTA (international format without + sign)
# Example: 972501234567 for Israeli number
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Cal.com booking link (optional, v2 feature)
# Format: username/event-slug (e.g., gal-moussan/30min)
# Leave empty in v1 - all CTAs will use WhatsApp
# When populated in v2, primary CTA opens Cal.com modal with WhatsApp as fallback
NEXT_PUBLIC_CAL_LINK=
